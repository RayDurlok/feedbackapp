	<licence>AGPL-3.0-or-later</licence>
	<author homepage="https://github.com/RayDurlok">Jakob</author>
	<documentation>
		<user>https://github.com/RayDurlok/feedbackapp#readme</user>
		<admin>https://github.com/RayDurlok/feedbackapp#readme</admin>
		<developer>https://github.com/RayDurlok/feedbackapp#readme</developer>
	</documentation>
	<category>multimedia</category>
	<category>files</category>
	<website>https://github.com/RayDurlok/feedbackapp</website>
	<bugs>https://github.com/RayDurlok/feedbackapp/issues</bugs>
	<repository>https://github.com/RayDurlok/feedbackapp</repository>
	<donation>https://buymeacoffee.com/hesoyammw3k</donation>
	<namespace>FeedbackApp</namespace>
	<types>
		<filesystem/>
	</types>
	<settings>
		<admin>OCA\FeedbackApp\Settings\Admin</admin>
		<admin-section>OCA\FeedbackApp\Settings\Section</admin-section>
